<configuration>
    <!-- 1. Định nghĩa Appender (Nơi log sẽ xuất hiện) -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Định dạng log chuyên nghiệp: Thời gian [Luồng] Mức-độ Tên-Class - Thông điệp -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 2. Cấu hình mức độ Log (Logging Levels) -->
    <!-- Mức ROOT: Áp dụng cho toàn bộ dự án -->
    <root level="info">
        <appender-ref ref="STDOUT" />
    </root>

    <!-- Mức riêng cho package banksystem: Để thấy rõ các debug giao dịch -->
    <logger name="com.banksystem" level="debug" additivity="false">
        <appender-ref ref="STDOUT" />
    </logger>
</configuration>